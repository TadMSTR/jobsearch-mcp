# job-watcher.env — least-privilege env for the job-watcher container
# Copy to job-watcher.env and fill in values before deploy.
# This file intentionally omits ANTHROPIC_API_KEY, FIRECRAWL_URL, QDRANT_URL, etc.
# — the watcher does not use them.

POSTGRES_URL=postgresql://user:password@jobsearch-postgres:5432/jobsearch
OLLAMA_HOST=
OLLAMA_EMBED_MODEL=bge-m3

# SMTP (Brevo free tier — register at brevo.com, verify SPF/DKIM on your sending domain)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@example.com
SMTP_PASSWORD=your_brevo_smtp_password
SMTP_FROM=alerts@yourdomain.com

# How often the watcher runs (seconds). Default: 4 hours
JOB_WATCH_INTERVAL_SECONDS=14400
