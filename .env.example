# Postgres — used by the jobsearch-postgres container and the MCP server
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Adzuna API — powers search_jobs and salary_insights
# Get a free API key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Firecrawl — extracts clean text from job listing URLs
# Self-host: https://github.com/mendableai/firecrawl
# Or use the hosted API: https://firecrawl.dev
FIRECRAWL_URL=http://localhost:3002

# Voyage AI — generates embeddings for semantic job matching
# Get an API key at https://dash.voyageai.com/
VOYAGE_API_KEY=

# Anthropic — used by score_fit for resume/JD analysis (uses claude-haiku-4-5)
# Get an API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
