# Postgres — used by the jobsearch-postgres container and the MCP server
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Adzuna API — powers search_jobs and salary_insights
# Get a free API key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Firecrawl Simple — extracts clean text from job listing URLs
# Self-host: https://github.com/trieve-ai/firecrawl-simple
FIRECRAWL_URL=http://localhost:3002

# Crawl4AI — second-tier fallback for job content extraction
# Runs on claudebox host at port 11235; from Docker: host.docker.internal:11235
CRAWL4AI_URL=http://host.docker.internal:11235

# Anthropic — used by score_fit, tailor_resume, build_profile (claude-haiku-4-5)
# Get an API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama embeddings — bge-m3 on forge (replaces Voyage AI cloud API)
# Resume/profile data stays local (not sent to cloud embedding API)
OLLAMA_HOST=
OLLAMA_EMBED_MODEL=bge-m3

# Valkey cache — 6h TTL for enriched job content
# Automatically configured via docker-compose; no changes needed for local dev
VALKEY_URL=redis://jobsearch-valkey:6379

# USAJobs — US federal government job listings (free, requires registration)
# Register at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Findwork — developer/tech job listings (free API key)
# Register at https://findwork.dev/
FINDWORK_API_KEY=

# SMTP for job alert emails (job-watcher service)
# See job-watcher.env.example for the watcher-specific env file
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
JOB_WATCH_INTERVAL_SECONDS=14400
